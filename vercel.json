{
  "framework": "nextjs",
  "installCommand": "npx --yes pnpm@9.14.4 install --no-frozen-lockfile",
  "buildCommand": "npx pnpm@9.14.4 run build",
  "outputDirectory": ".next",
  "headers": [
    {
      "source": "/admin",
      "headers": [
        { "key": "Cache-Control", "value": "no-store, no-cache, must-revalidate, private, max-age=0, s-maxage=0" },
        { "key": "CDN-Cache-Control", "value": "no-store" },
        { "key": "Vercel-CDN-Cache-Control", "value": "no-store" }
      ]
    },
    {
      "source": "/admin/:path*",
      "headers": [
        { "key": "Cache-Control", "value": "no-store, no-cache, must-revalidate, private, max-age=0, s-maxage=0" },
        { "key": "CDN-Cache-Control", "value": "no-store" },
        { "key": "Vercel-CDN-Cache-Control", "value": "no-store" }
      ]
    }
  ]
}
