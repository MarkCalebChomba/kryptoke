{
  "framework": "nextjs",
  "installCommand": "npx --yes pnpm@9.14.4 install --no-frozen-lockfile",
  "buildCommand": "npx pnpm@9.14.4 run build",
  "outputDirectory": ".next",
  "headers": [
    {
      "source": "/admin",
      "headers": [
        { "key": "Cache-Control", "value": "no-store, no-cache, must-revalidate, private, max-age=0, s-maxage=0" },
        { "key": "CDN-Cache-Control", "value": "no-store" },
        { "key": "Vercel-CDN-Cache-Control", "value": "no-store" }
      ]
    },
    {
      "source": "/admin/:path*",
      "headers": [
        { "key": "Cache-Control", "value": "no-store, no-cache, must-revalidate, private, max-age=0, s-maxage=0" },
        { "key": "CDN-Cache-Control", "value": "no-store" },
        { "key": "Vercel-CDN-Cache-Control", "value": "no-store" }
      ]
    },
    {
      "source": "/api/v1/market/prices",
      "headers": [
        { "key": "Cache-Control", "value": "public, s-maxage=15, stale-while-revalidate=30" },
        { "key": "CDN-Cache-Control", "value": "public, max-age=15" }
      ]
    },
    {
      "source": "/api/v1/market/home",
      "headers": [
        { "key": "Cache-Control", "value": "public, s-maxage=15, stale-while-revalidate=30" },
        { "key": "CDN-Cache-Control", "value": "public, max-age=15" }
      ]
    },
    {
      "source": "/api/v1/tokens",
      "headers": [
        { "key": "Cache-Control", "value": "public, s-maxage=60, stale-while-revalidate=120" },
        { "key": "CDN-Cache-Control", "value": "public, max-age=60" }
      ]
    },
    {
      "source": "/api/v1/config/:path*",
      "headers": [
        { "key": "Cache-Control", "value": "public, s-maxage=300, stale-while-revalidate=600" },
        { "key": "CDN-Cache-Control", "value": "public, max-age=300" }
      ]
    },
    {
      "source": "/api/v1/market/fear-greed",
      "headers": [
        { "key": "Cache-Control", "value": "public, s-maxage=3600, stale-while-revalidate=7200" },
        { "key": "CDN-Cache-Control", "value": "public, max-age=3600" }
      ]
    }
  ]
}
