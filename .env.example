# ─────────────────────────────────────────────────────────────────────────────
# KryptoKe — Complete Environment Variables
# Copy this file to .env.local for local development
# NEVER commit .env.local to version control
# Generate secrets with: openssl rand -base64 64
# ─────────────────────────────────────────────────────────────────────────────

# ── App ───────────────────────────────────────────────────────────────────────
NODE_ENV=development
NEXT_PUBLIC_APP_VERSION=1.0.0
NEXT_PUBLIC_APP_ENV=development
NEXT_PUBLIC_API_URL=http://localhost:3000/api/v1

# ── Supabase ──────────────────────────────────────────────────────────────────
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# ── Upstash Redis ─────────────────────────────────────────────────────────────
UPSTASH_REDIS_REST_URL=https://your-db.upstash.io
UPSTASH_REDIS_REST_TOKEN=your-upstash-token

# ── JWT ───────────────────────────────────────────────────────────────────────
# openssl rand -base64 64
JWT_SECRET=your-very-long-random-secret-minimum-64-chars

# ── M-Pesa (Safaricom Daraja) ─────────────────────────────────────────────────
MPESA_CONSUMER_KEY=your-consumer-key
MPESA_CONSUMER_SECRET=your-consumer-secret
MPESA_PASSKEY=your-stk-push-passkey
MPESA_PAYBILL=your-paybill-number
MPESA_B2C_SHORTCODE=your-b2c-shortcode
MPESA_B2C_INITIATOR_NAME=your-initiator-name
MPESA_B2C_INITIATOR_PASSWORD=your-b2c-password
MPESA_CALLBACK_BASE_URL=https://your-domain.com
# Production only — Safaricom certificate for encrypting the initiator password
# Download from Safaricom Daraja portal → Production Credentials
MPESA_SAFARICOM_CERT=-----BEGIN CERTIFICATE-----\n...\n-----END CERTIFICATE-----
MPESA_ENVIRONMENT=sandbox

# ── HD Wallet (CRITICAL — back up offline, never share) ───────────────────────
# Generate: node -e "const {ethers}=require('ethers'); console.log(ethers.Wallet.createRandom().mnemonic.phrase)"
MASTER_SEED_PHRASE=word1 word2 word3 word4 word5 word6 word7 word8 word9 word10 word11 word12

# EVM hot wallet (derived from master seed at index 0)
HOT_WALLET_ADDRESS=0x...your-hot-wallet-address

# ── Non-EVM Hot Wallets (memo/tag-based shared addresses) ─────────────────────
# These are your exchange hot wallets for XRP, TON, Stellar
# Users send to these addresses with a unique memo — do NOT use personal wallets
XRP_HOT_WALLET_ADDRESS=r...your-xrp-address
TON_HOT_WALLET_ADDRESS=EQ...your-ton-address
XLM_HOT_WALLET_ADDRESS=G...your-stellar-address

# ── Cron Security ─────────────────────────────────────────────────────────────
# Used to authenticate /api/v1/cron/deposit-monitor calls from cron-job.org
# openssl rand -hex 32
CRON_SECRET=your-cron-secret-here

# ── TRON ──────────────────────────────────────────────────────────────────────
TRON_USDT_CONTRACT=TR7NHqjeKQxGTCi8q8ZY4pL8otSzgjLj6t
TRON_API_URL=https://api.trongrid.io
# Optional: get from trongrid.io for higher rate limits
TRONGRID_API_KEY=

# ── Solana ────────────────────────────────────────────────────────────────────
SOLANA_RPC_URL=https://api.mainnet-beta.solana.com
# USDT SPL token mint address (mainnet)
SOL_USDT_MINT=Es9vMFrzaCERmJfrF4H2FYD4KCoNkY11McCe8BenwNYB

# ── Bitcoin-family public APIs (no key needed for basic use) ──────────────────
BLOCKSTREAM_API_URL=https://blockstream.info/api
LTC_API_URL=https://ltc1.trezor.io/api
DOGE_API_URL=https://api.blockcypher.com/v1/doge/main
BCH_API_URL=https://bch1.trezor.io/api

# ── XRP ───────────────────────────────────────────────────────────────────────
XRP_RPC_URL=https://xrplcluster.com

# ── TON ───────────────────────────────────────────────────────────────────────
TON_API_URL=https://toncenter.com/api/v2
# Optional: get from toncenter.com for higher rate limits
TONCENTER_API_KEY=

# ── Stellar ───────────────────────────────────────────────────────────────────
STELLAR_HORIZON_URL=https://horizon.stellar.org

# ── NEAR ──────────────────────────────────────────────────────────────────────
NEAR_RPC_URL=https://rpc.mainnet.near.org
NEAR_INDEXER_URL=https://api.nearblocks.io/v1

# ── Filecoin ──────────────────────────────────────────────────────────────────
FIL_API_URL=https://api.node.glif.io/rpc/v1
FIL_INDEXER_URL=https://api.zondax.ch/fil/data/v3/mainnet
# Optional: JWT for authenticated Glif node access (higher limits)
GLIF_JWT=

# ── EVM RPC Endpoints (free public — swap for paid for production) ────────────
ETH_RPC_URL=https://eth.llamarpc.com
BSC_RPC_URL=https://bsc-dataseed.binance.org
POLYGON_RPC_URL=https://polygon-rpc.com
ARBITRUM_RPC_URL=https://arb1.arbitrum.io/rpc
OPTIMISM_RPC_URL=https://mainnet.optimism.io
BASE_RPC_URL=https://mainnet.base.org
AVALANCHE_RPC_URL=https://api.avax.network/ext/bc/C/rpc
FANTOM_RPC_URL=https://rpc.ftm.tools
LINEA_RPC_URL=https://rpc.linea.build
ZKSYNC_RPC_URL=https://mainnet.era.zksync.io
SCROLL_RPC_URL=https://rpc.scroll.io
MANTLE_RPC_URL=https://rpc.mantle.xyz
GNOSIS_RPC_URL=https://rpc.gnosischain.com
CELO_RPC_URL=https://forno.celo.org

# ── Etherscan V2 (one key covers all EVM chains) ──────────────────────────────
# Get from: https://etherscan.io → My Account → API Keys
ETHERSCAN_API_KEY=your-etherscan-api-key

# ── Forex (KES/USD rate) ──────────────────────────────────────────────────────
EXCHANGE_RATE_API_URL=https://api.frankfurter.app/latest?from=USD&to=KES
# Optional: exchangerate-api.com key for higher reliability
EXCHANGE_RATE_API_KEY=

# ── Africa's Talking (SMS OTP) ────────────────────────────────────────────────
AFRICASTALKING_USERNAME=sandbox
AFRICASTALKING_API_KEY=your-at-api-key
AFRICASTALKING_SENDER_ID=KRYPTOKE

# ── Resend (Transactional Email) ──────────────────────────────────────────────
RESEND_API_KEY=re_your_resend_key
RESEND_FROM_EMAIL=noreply@kryptoke.com

# ── Sentry (Error Monitoring) ─────────────────────────────────────────────────
SENTRY_DSN=https://your-key@sentry.io/project-id
NEXT_PUBLIC_SENTRY_DSN=https://your-key@sentry.io/project-id
SENTRY_ORG=your-sentry-org
SENTRY_PROJECT=kryptoke
SENTRY_AUTH_TOKEN=your-sentry-auth-token

# ── Admin ─────────────────────────────────────────────────────────────────────
ADMIN_EMAIL=admin@kryptoke.com

# ── Internal secrets ──────────────────────────────────────────────────────────
# openssl rand -hex 32
INTERNAL_SECRET=your-internal-secret
SWEEP_SECRET=your-sweep-secret

# ─────────────────────────────────────────────────────────────────────────────
# CRON-JOB.ORG SETUP
# Create two jobs at minute :00 and :30 of every minute:
#   URL:    https://your-domain.com/api/v1/cron/deposit-monitor
#   Method: POST
#   Header: X-Cron-Secret: <your CRON_SECRET value>
# ─────────────────────────────────────────────────────────────────────────────

# ─────────────────────────────────────────────────────────────────────────────
# SUPABASE MIGRATIONS — run in order in the SQL editor:
#   1. supabase/migrations/000_quick_setup.sql
#   2. supabase/migrations/001_initial_schema.sql
#   3. supabase/migrations/002_rls_and_indexes.sql
#   4. supabase/migrations/003_multichain.sql
#   5. supabase/migrations/004_multichain_v2.sql
#   6. supabase/migrations/005_withdrawal_queue_and_fixes.sql
# ─────────────────────────────────────────────────────────────────────────────
